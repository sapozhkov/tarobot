# Локальная конфигурация Tarobot.
# Скопируйте этот файл в .env.local и заполните нужные значения.

# Провайдеры по умолчанию.
TAROBOT_LLM_PROVIDER=yandex
TAROBOT_TTS_PROVIDER=yandex

# Общий API-ключ сервисного аккаунта Yandex Cloud.
YANDEX_API_KEY=replace-with-your-api-key

# Для LLM можно указать либо folder id + model name, либо сразу готовый model URI.
YANDEX_FOLDER_ID=replace-with-your-folder-id
YANDEX_LLM_MODEL=yandexgpt
YANDEX_LLM_MODEL_URI=
YANDEX_LLM_TEMPERATURE=0.75
YANDEX_LLM_MAX_TOKENS=1800

# Необязательные параметры для SpeechKit.
# Актуальные голоса и амплуа: https://yandex.cloud/en/docs/speechkit/tts/voices
YANDEX_TTS_VOICE=zamira_ru
YANDEX_TTS_ROLE=friendly
YANDEX_TTS_SPEED=1.0
YANDEX_TTS_PITCH_SHIFT=0
YANDEX_TTS_LOUDNESS_NORMALIZATION_TYPE=LUFS
YANDEX_TTS_VOLUME=
