# Локальная конфигурация Tarobot.
# Скопируйте этот файл в .env.local и заполните нужные значения.

# Провайдер TTS, который будем использовать по умолчанию.
TAROBOT_TTS_PROVIDER=yandex

# API-ключ сервисного аккаунта Yandex Cloud для SpeechKit TTS.
YANDEX_API_KEY=replace-with-your-api-key

# Необязательные параметры для SpeechKit.
# Актуальные голоса и амплуа: https://yandex.cloud/en/docs/speechkit/tts/voices
YANDEX_TTS_VOICE=marina
YANDEX_TTS_ROLE=friendly
YANDEX_TTS_SPEED=1.0
YANDEX_TTS_PITCH_SHIFT=0
